# Copy this file to `.env` and configure your model provider.
#
# The chatbot uses a centralized LLM backend powered by LiteLLM, which supports
# 100+ LLM providers. See backend/LLM_CONFIG_EXAMPLES.md for detailed examples.

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Option 1: Ollama (Local, No API Key Required) - DEFAULT
# Install: https://ollama.ai
# Run: ollama pull llama3.2
MODEL_NAME=ollama/llama3.2

# Option 2: OpenAI (Requires API Key)
# MODEL_NAME=openai/gpt-4o-mini
# OPENAI_API_KEY=your-key-here

# Option 3: Anthropic Claude (Requires API Key)
# MODEL_NAME=anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your-key-here

# Option 4: GitHub Copilot (Requires GitHub Copilot Subscription)
# Uses OAuth device flow - you'll be prompted to authenticate on first use
# MODEL_NAME=github_copilot/gpt-4

# Option 5: Other Ollama models
# MODEL_NAME=ollama/qwen2.5:7b
# MODEL_NAME=ollama/mistral
# MODEL_NAME=ollama/phi3

# Option 6: llama.cpp local server (No API Key Required)
# Start server: ./llama-server -m model.gguf
# MODEL_NAME=openai/local-model
# OPENAI_API_BASE=http://localhost:8080/v1

# =============================================================================
# JUDGE MODEL (for evaluations - can be smaller/cheaper)
# =============================================================================
MODEL_NAME_JUDGE=ollama/llama3.2
# MODEL_NAME_JUDGE=github_copilot/gpt-4

# =============================================================================
# TEMPERATURE CONFIGURATION (optional)
# =============================================================================
# MODEL_TEMPERATURE=0.7  # Default: 0.7 (range: 0.0-1.0)

# =============================================================================
# API KEYS (only needed for cloud providers)
# =============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# TOGETHER_API_KEY=
# GEMINI_API_KEY=